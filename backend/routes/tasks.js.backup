// ---------------- DELETE MEDIA (OWN SUBMISSION) ----------------
router.delete("/media/:mediaId", authMiddleware, async (req, res) => {
  try {
    const { mediaId } = req.params;
    const Media = require("../models/Media");

    const media = await Media.findById(mediaId);
    if (!media) {
      return res.status(404).json({ error: "Media not found" });
    }

    // Only allow deletion if:
    // 1. User is the uploader
    // 2. Status is still 'pending' (not yet approved/rejected)
    if (media.uploadedBy.toString() !== req.user.id) {
      return res.status(403).json({ error: "Not authorized to delete this media" });
    }

    if (media.status !== 'pending') {
      return res.status(400).json({ error: "Cannot delete media that has already been reviewed" });
    }

    // Delete the file from filesystem
    const fs = require('fs');
    const path = require('path');
    if (fs.existsSync(media.filePath)) {
      fs.unlinkSync(media.filePath);
    }

    await Media.findByIdAndDelete(mediaId);
    res.json({ message: "Media deleted successfully" });
  } catch (err) {
    console.error("Delete Media Error:", err);
    res.status(500).json({ error: "Internal Server Error" });
  }
});

// ---------------- UPDATE MEDIA (DESCRIPTION AND/OR FILE) ----------------
router.patch("/media/:mediaId/update", authMiddleware, uploadExtended.single('file'), async (req, res) => {
  try {
    const { mediaId } = req.params;
    const { description } = req.body;
    const Media = require("../models/Media");
    const fs = require('fs');
    
    const media = await Media.findById(mediaId);
    if (!media) {
      return res.status(404).json({ error: "Media not found" });
    }

    if (media.uploadedBy.toString() !== req.user.id) {
      return res.status(403).json({ error: "Not authorized to update this media" });
    }

    if (media.status !== 'pending') {
      return res.status(400).json({ error: "Cannot update media that has already been reviewed" });
    }

    // Update description if provided
    if (description !== undefined) {
      media.description = description;
    }

    // Replace file if new one is uploaded
    if (req.file) {
      // Delete old file from filesystem
      if (fs.existsSync(media.filePath)) {
        fs.unlinkSync(media.filePath);
      }

      // Update with new file info
      media.fileName = req.file.filename;
      media.fileType = req.file.mimetype.startsWith('image') ? 'image' : 
                       req.file.mimetype.startsWith('video') ? 'video' : 'document';
      media.filePath = req.file.path;
    }

    await media.save();
    res.json({ message: "Media updated successfully", media });
  } catch (err) {
    console.error("Update Media Error:", err);
    res.status(500).json({ error: "Internal Server Error" });
  }
});

// quick endpoint to fetch all events ...
router.get("/events", authMiddleware, async (req, res) => {
  try {
    // For admin: show all tasks; for members: only assignedTo
    let match = {};
    if (req.user.role === 'clubmember') {
      match.assignedTo = req.user.id;
    }
    const tasks = await Task.find(match).select('title deadline status recurrence').lean();
    // include media submission dates for the user
    const Media = require("../models/Media");
    const mediaMatch = req.user.role === 'clubmember' ? { uploadedBy: req.user.id } : {};
    const medias = await Media.find(mediaMatch).select('fileName createdAt taskId status').lean();

    res.json({ tasks, medias });
  } catch (err) {
    console.error("Events Error:", err);
    res.status(500).json({ error: "Internal Server Error" });
  }
});


module.exports = router;
```